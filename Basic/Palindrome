number = int(input("Enter your number"))
original_number = number

reversed_num = 0

while number > 0:
    reversed_num = reversed_num * 10 + number % 10
    number = number // 10

if original_number == reversed_num:
    print(f"Given number {original_number} is palindrome")
else:
    print(f"Given number {original_number} is not palindrome")
